# ─── FRONTEND & DEPENDENCIES ───────────────────────────────────────────────
# Ignore node_modules as they are installed via 'npm install'
node_modules
# Ignore production build outputs
dist
dist-ssr
# Ignore local environment variables and overrides
*.local

# ─── BACKEND & PYTHON ───────────────────────────────────────────────────────
# Ignore compiled Python files and cache to keep the repo clean
__pycache__/
*.pyc
# Ignore temporary schema checks and setup scripts
*check_schema.py
*update_postman.project_setup_files.zip

# ─── DATABASE & STORAGE ─────────────────────────────────────────────────────
# Ignore SQLite database files to prevent leaking production/test data
# The database (lumiere.db) is generated locally by seed_db.py
*.db

# ─── LOGS & DEBUGGING ───────────────────────────────────────────────────────
# Ignore error logs generated by the system or package managers
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── EDITOR & OS NOISE ──────────────────────────────────────────────────────
# Ignore IDE specific configuration files (VSCode, IntelliJ, etc.)
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── SCRATCH & TEMPORARY ───────────────────────────────────────────────────
# Ignore scratch files used during development
*.scratch

# ─── PROJECT DOCUMENTATION (EXPLICITLY TRACKED) ──────────────────────────
# These files are kept in the repo for partner onboarding and API reference
# API_Integration_Plan.md
# Backend_Api_Documentation.md
# setup_instructions.md
